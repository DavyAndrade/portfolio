---
import Layout from "../layouts/Layout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter, CardAction } from "../components/ui/card";
import Typography from "../components/ui/Typography.vue";
---

<Layout title="Design System">
  

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

  <!-- Noise overlay -->
  <div class="pointer-events-none fixed inset-0 z-100 opacity-[0.035] mix-blend-overlay" style="background-image: url(data:image/svg+xml;base64,); background-repeat: repeat; background-size: 256px 256px;"></div>

  <nav class="fixed top-4 inset-x-4 z-50 mx-auto flex h-14 max-w-6xl items-center justify-between rounded-full border border-white/10 bg-black/70 px-6 shadow-heavy backdrop-blur reveal">
    <a class="text-sm font-bold uppercase tracking-[0.15em] text-white" href="#">DESIGN.md</a>
    <ul class="hidden items-center gap-6 text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-muted sm:flex">
      <li><a class="transition hover:text-white" href="#colors">Colors</a></li>
      <li><a class="transition hover:text-white" href="#typography">Typography</a></li>
      <li><a class="transition hover:text-white" href="#buttons">Buttons</a></li>
      <li><a class="transition hover:text-white" href="#cards">Cards</a></li>
      <li><a class="transition hover:text-white" href="#forms">Forms</a></li>
      <li><a class="transition hover:text-white" href="#spacing">Spacing</a></li>
      <li><a class="transition hover:text-white" href="#radius">Radius</a></li>
      <li><a class="transition hover:text-white" href="#depth">Depth</a></li>
    </ul>
    <a
      class="btn-hover inline-flex items-center justify-center rounded-full bg-green px-5 py-1.5 text-[0.65rem] font-bold uppercase tracking-[0.15em] text-black shadow-medium hover:bg-green-border"
      href="#"
    >Explore</a>
  </nav>

  <!-- Hero -->
  <section class="relative flex min-h-screen flex-col items-center justify-center gap-6 overflow-hidden px-6 text-center">
    <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 80% 50% at 50% 40%, color-mix(in srgb, var(--catppuccin-color-mauve) 12%, transparent), transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background: radial-gradient(ellipse 50% 30% at 50% 30%, color-mix(in srgb, var(--catppuccin-color-mauve) 8%, transparent), transparent 60%); animation: hero-glow 4s ease-in-out infinite"></div>
    <div class="flex flex-col items-center gap-5 reveal">
      <span class="inline-block rounded-full bg-green/10 px-4 py-1 text-[0.6rem] font-bold uppercase tracking-[0.25em] text-green">Design Token Catalog</span>
      <h1 class="max-w-3xl font-title text-5xl font-bold leading-[1.05] text-white sm:text-6xl lg:text-7xl">
        Design System<br>Inspired by <span class="text-green" style="animation: pulse-glow 3s ease-in-out infinite">Catppuccin</span>
      </h1>
      <p class="max-w-xl text-base text-muted sm:text-lg">
        A design token catalog generated from <span class="font-mono text-xs text-near-white">DESIGN.md</span>. Every color, font, and component — visualized in mocha dark.
      </p>
    </div>
    <div class="reveal reveal-delay-1 flex items-center gap-3">
      <a
        class="btn-hover inline-flex items-center justify-center rounded-full bg-green px-8 py-3 text-xs font-bold uppercase tracking-[0.15em] text-black shadow-medium hover:bg-green-border"
        href="#"
      >Get Started</a>
      <a
        class="btn-hover inline-flex items-center justify-center rounded-full border border-border-light px-8 py-3 text-xs font-bold uppercase tracking-[0.15em] text-white hover:border-white"
        href="#"
      >Learn More</a>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Colors -->
  <section id="colors" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">01 / Colors</Typography>
      <Typography variant="h1" as="h2">Color Palette</Typography>
      <Typography variant="muted" class="max-w-lg">Every color token in the system — brand, surface, text, and semantic roles.</Typography>
    </div>
    <div class="reveal reveal-delay-1">
      <span class="mb-4 block text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-muted">Brand</span>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-green"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Catppuccin Green</CardTitle>
            <CardDescription>--color-green</CardDescription>
            <span class="text-[0.65rem] text-separator">Brand accent</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-zinc-950"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Near Black</CardTitle>
            <CardDescription>bg-zinc-950</CardDescription>
            <span class="text-[0.65rem] text-separator">Page background</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 border border-white/10 bg-surface"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Surface</CardTitle>
            <CardDescription>--color-surface</CardDescription>
            <span class="text-[0.65rem] text-separator">Cards, containers</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-surface-mid"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Mid Dark</CardTitle>
            <CardDescription>--color-surface-mid</CardDescription>
            <span class="text-[0.65rem] text-separator">Buttons, inputs</span>
          </CardContent>
        </Card>
      </div>
    </div>
    <div class="reveal reveal-delay-2">
      <span class="mb-4 block text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-muted">Text &amp; Semantic</span>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-white"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>White</CardTitle>
            <CardDescription>text-white</CardDescription>
            <span class="text-[0.65rem] text-separator">Primary text</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-muted"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Silver</CardTitle>
            <CardDescription>--color-muted</CardDescription>
            <span class="text-[0.65rem] text-separator">Secondary text</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-negative"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Negative</CardTitle>
            <CardDescription>--color-negative</CardDescription>
            <span class="text-[0.65rem] text-separator">Error states</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-warning"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Warning</CardTitle>
            <CardDescription>--color-warning</CardDescription>
            <span class="text-[0.65rem] text-separator">Warning states</span>
          </CardContent>
        </Card>
        <Card variant="surface" padding="none" hover class="overflow-hidden">
          <div class="color-swatch-block h-24 bg-info"></div>
          <CardContent class="flex flex-col gap-0.5 p-4">
            <CardTitle>Info</CardTitle>
            <CardDescription>--color-info</CardDescription>
            <span class="text-[0.65rem] text-separator">Info states</span>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Typography -->
  <section id="typography" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">02 / Typography</Typography>
      <Typography variant="h1" as="h2">Typography Scale</Typography>
      <Typography variant="muted" class="max-w-lg">Font families: <span class="font-title text-white">font-title</span> (display) + <span class="font-ui text-white">font-ui</span> (body). Compact and functional.</Typography>
    </div>
    <div class="flex flex-col gap-4">
      <Card class="type-sample">
        <CardHeader>
          <CardTitle class="font-title text-2xl font-bold text-white">Section Title — Your Playlists</CardTitle>
        </CardHeader>
        <CardDescription>Title — 24px / 700 / font-title</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardHeader>
          <CardTitle class="font-ui text-lg font-semibold leading-tight text-white">Feature Heading — Made for You</CardTitle>
        </CardHeader>
        <CardDescription>Feature — 18px / 600 / 1.30</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardHeader>
          <CardTitle class="font-ui text-base font-bold text-white">Body Bold — Liked Songs</CardTitle>
        </CardHeader>
        <CardDescription>Body Bold — 16px / 700</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardContent>
          <div class="font-ui text-sm text-muted">Caption — 3 min 42 sec</div>
        </CardContent>
        <CardDescription>Caption — 14px / 400</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardHeader>
          <CardTitle class="font-ui text-sm font-bold uppercase tracking-widest text-white">SHUFFLE PLAY</CardTitle>
        </CardHeader>
        <CardDescription>Button Uppercase — 14px / 700 / uppercase / +1.4px</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardContent>
          <div class="font-ui text-xs font-bold text-muted">Small Bold — 1,234 songs</div>
        </CardContent>
        <CardDescription>Small Bold — 12px / 700</CardDescription>
      </Card>
      <Card class="type-sample">
        <CardContent>
          <div class="font-ui text-[0.66rem] font-semibold capitalize text-muted">Badge — Playlist</div>
        </CardContent>
        <CardDescription>Badge — 10.5px / 600 / capitalize</CardDescription>
      </Card>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Buttons -->
  <section id="buttons" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">03 / Buttons</Typography>
      <Typography variant="h1" as="h2">Button Variants</Typography>
      <Typography variant="muted" class="max-w-lg">Pill geometry, uppercase labels, and a single green accent. Four distinct personalities.</Typography>
    </div>
    <div class="reveal reveal-delay-1 flex flex-wrap items-center gap-5">
      <div class="flex flex-col items-center gap-2">
        <a class="btn-hover inline-flex items-center justify-center rounded-full bg-green px-8 py-3 text-xs font-bold uppercase tracking-[0.15em] text-black shadow-medium hover:bg-green-border" href="#">Shuffle Play</a>
        <span class="text-[0.55rem] uppercase tracking-[0.25em] text-separator">Green Pill</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <a class="btn-hover inline-flex items-center justify-center rounded-full bg-surface-mid px-8 py-3 text-xs font-bold uppercase tracking-[0.15em] text-white shadow-medium hover:brightness-110" href="#">Browse</a>
        <span class="text-[0.55rem] uppercase tracking-[0.25em] text-separator">Dark Pill</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <a class="btn-hover inline-flex items-center justify-center rounded-full border border-border-light px-8 py-3 text-xs font-bold uppercase tracking-[0.15em] text-white hover:border-white" href="#">Follow</a>
        <span class="text-[0.55rem] uppercase tracking-[0.25em] text-separator">Outlined</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <a class="btn-hover inline-flex h-12 w-12 items-center justify-center rounded-full bg-surface-mid text-lg text-white shadow-heavy hover:brightness-110" href="#" aria-label="Play">▶</a>
        <span class="text-[0.55rem] uppercase tracking-[0.25em] text-separator">Play Circle</span>
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Cards -->
  <section id="cards" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">04 / Cards</Typography>
      <Typography variant="h1" as="h2">Card Examples</Typography>
      <Typography variant="muted" class="max-w-lg">Surface containers with optional elevation. Hover lifts them into focus.</Typography>
    </div>
    <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <Card variant="surface" padding="sm" hover>
        <CardTitle>Discover Weekly</CardTitle>
        <CardDescription class="mt-1">Your personal playlist, updated every Monday.</CardDescription>
      </Card>
      <Card variant="surface" padding="sm" hover>
        <CardTitle>Release Radar</CardTitle>
        <CardDescription class="mt-1">New releases from artists you follow.</CardDescription>
      </Card>
      <Card variant="surface" padding="sm" hover>
        <CardTitle>Daily Mix 1</CardTitle>
        <CardDescription class="mt-1">Made for you based on your listening.</CardDescription>
      </Card>
      <Card variant="surface" padding="sm" hover>
        <CardTitle>Liked Songs</CardTitle>
        <CardDescription class="mt-1">Your saved songs collection.</CardDescription>
      </Card>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Forms -->
  <section id="forms" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">05 / Forms</Typography>
      <Typography variant="h1" as="h2">Form Elements</Typography>
      <Typography variant="muted" class="max-w-lg">Pill-shaped inputs with inset shadow borders. Focus and error states via colored rings.</Typography>
    </div>
    <div class="reveal reveal-delay-1 flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <label class="text-xs font-bold uppercase tracking-[0.15em] text-muted">Search</label>
        <input
          class="w-full rounded-full bg-surface-mid px-4 py-3 text-sm text-white shadow-inset outline-none transition-shadow duration-300 placeholder:text-separator focus:shadow-[rgb(18,18,18)_0px_1px_0px,var(--catppuccin-color-green)_0px_0px_0px_1px_inset]"
          type="search"
          placeholder="Artists, songs, or podcasts"
        >
        <span class="text-[0.6rem] text-separator">Default (inset border) → Focus (green ring)</span>
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-bold uppercase tracking-[0.15em] text-muted">Email</label>
        <input
          class="w-full rounded-full bg-surface-mid px-4 py-3 text-sm text-white outline-none transition-shadow duration-300"
          style="box-shadow: rgb(18,18,18) 0px 1px 0px, var(--catppuccin-color-red) 0px 0px 0px 1px inset"
          type="email"
          value="invalid"
        >
        <span class="text-[0.6rem] text-separator">Error (red ring)</span>
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-xs font-bold uppercase tracking-[0.15em] text-muted">Description</label>
        <textarea
          class="w-full rounded-lg bg-surface-mid px-4 py-3 text-sm text-white shadow-inset outline-none transition-shadow duration-300 placeholder:text-separator focus:shadow-[rgb(18,18,18)_0px_1px_0px,var(--catppuccin-color-green)_0px_0px_0px_1px_inset]"
          placeholder="Add a description..."
        ></textarea>
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Spacing -->
  <section id="spacing" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">06 / Spacing</Typography>
      <Typography variant="h1" as="h2">Spacing Scale</Typography>
      <Typography variant="muted" class="max-w-lg">Base unit is 8px. From tight compression to comfortable breathing room.</Typography>
    </div>
    <div class="reveal reveal-delay-1 flex items-end gap-4">
      <div class="flex flex-col items-center gap-2">
        <div class="h-10 w-1 rounded-t-sm bg-green transition-all duration-300 hover:h-14"></div>
        <span class="text-xs text-muted">4</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-10 w-2 rounded-t-sm bg-green transition-all duration-300 hover:h-14"></div>
        <span class="text-xs text-muted">8</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-10 w-3 rounded-t-sm bg-green transition-all duration-300 hover:h-14"></div>
        <span class="text-xs text-muted">12</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-10 w-4 rounded-t-sm bg-green transition-all duration-300 hover:h-14"></div>
        <span class="text-xs text-muted">16</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-10 w-5 rounded-t-sm bg-green transition-all duration-300 hover:h-14"></div>
        <span class="text-xs text-muted">20</span>
      </div>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Radius -->
  <section id="radius" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <Typography variant="sectionLabel">07 / Radius</Typography>
      <Typography variant="h1" as="h2">Border Radius</Typography>
      <Typography variant="muted" class="max-w-lg">From sharp 2px badges to pill-like 500px and full circles at 50%.</Typography>
    </div>
    <div class="reveal reveal-delay-1 flex flex-wrap items-end gap-6">
      <div class="flex flex-col items-center gap-2">
        <div class="h-12 w-12 bg-green transition-all duration-300 hover:scale-110" style="border-radius:2px"></div>
        <span class="text-xs text-muted">2px</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-12 w-12 rounded-md bg-green transition-all duration-300 hover:scale-110"></div>
        <span class="text-xs text-muted">6px</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-12 w-12 rounded-lg bg-green transition-all duration-300 hover:scale-110"></div>
        <span class="text-xs text-muted">8px</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="h-12 w-24 rounded-pill bg-green transition-all duration-300 hover:scale-105"></div>
        <span class="text-xs text-muted">500px</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="flex h-12 w-12 items-center justify-center rounded-circle bg-green text-xs font-bold text-black transition-all duration-300 hover:scale-110">50%</div>
        <span class="text-xs text-muted">50%</span>
      </div>
    </div>
  </section>

  <!-- Motion / Animation Tokens -->
  <section id="motion" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <span class="text-[0.6rem] font-bold uppercase tracking-[0.25em] text-muted">08 / Motion</span>
      <h2 class="font-title text-3xl font-bold text-white">Animation Tokens</h2>
      <p class="max-w-lg text-sm text-muted">Defined in <span class="font-mono text-xs text-near-white">@theme</span>. Use for entry, exit, and staggered reveals.</p>
    </div>
    <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <Card class="flex-col items-center gap-3 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-green text-lg font-bold text-black animate-fade-in" style="animation-iteration-count:infinite;animation-direction:alternate">fade</div>
        <CardTitle>fade-in</CardTitle>
        <CardDescription>opacity 0 → 1</CardDescription>
      </Card>
      <Card class="flex-col items-center gap-3 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-mauve text-lg font-bold text-black animate-slide-up" style="animation-iteration-count:infinite;animation-direction:alternate">up</div>
        <CardTitle>slide-up</CardTitle>
        <CardDescription>translateY + opacity</CardDescription>
      </Card>
      <Card class="flex-col items-center gap-3 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-blue text-lg font-bold text-black animate-scale-in" style="animation-iteration-count:infinite;animation-direction:alternate">+</div>
        <CardTitle>scale-in</CardTitle>
        <CardDescription>scale 0.95 + opacity</CardDescription>
      </Card>
      <Card class="flex-col items-center gap-3 text-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-peach text-lg font-bold text-black animate-fade-out" style="animation-iteration-count:infinite;animation-direction:alternate-reverse">out</div>
        <CardTitle>fade-out</CardTitle>
        <CardDescription>opacity 1 → 0</CardDescription>
      </Card>
    </div>
  </section>

  <div class="section-divider mx-auto max-w-4xl"></div>

  <!-- Depth -->
  <section id="depth" class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-6 py-20">
    <div class="reveal flex flex-col gap-2">
      <span class="text-[0.6rem] font-bold uppercase tracking-[0.25em] text-muted">09 / Elevation</span>
      <h2 class="font-title text-3xl font-bold text-white">Depth</h2>
      <p class="max-w-lg text-sm text-muted">Four levels of elevation. Shadows turn up the drama against dark backgrounds.</p>
    </div>
    <div class="reveal reveal-delay-1 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg bg-zinc-950 p-6">
        <span class="text-sm font-bold text-white">Base</span>
        <p class="mt-1 text-xs text-separator">Flat against the void</p>
      </div>
      <div class="rounded-lg bg-surface-mid p-6">
        <span class="text-sm font-bold text-white">Surface</span>
        <p class="mt-1 text-xs text-separator">One layer above</p>
      </div>
      <Card variant="surface" padding="default" hover>
        <CardTitle>Elevated</CardTitle>
        <CardDescription class="mt-1">Lifted — <span class="font-mono text-near-white">shadow-medium</span></CardDescription>
      </Card>
      <Card variant="elevated" padding="default" hover>
        <CardTitle>Dialog</CardTitle>
        <CardDescription class="mt-1">Floating — <span class="font-mono text-near-white">shadow-heavy</span></CardDescription>
      </Card>
    </div>
  </section>
</Layout>

<style>
    .reveal {
      opacity: 0;
      translate: 0 24px;
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), translate 0.6s cubic-bezier(0.16, 1, 0.3, 1);
