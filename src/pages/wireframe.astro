---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Wireframe - Portfolio">
  <div class="wireframe">
    <!-- ─── HEADER / LEGEND ─── -->
    <header class="wireframe-header py-8">
      <div class="max-w-6xl mx-auto px-6 py-10">
        <h1 class="wireframe-title">Wireframe — Portfolio</h1>
        <p class="wireframe-subtitle">Estrutura visual completa com design tokens Catppuccin Mocha</p>

        <div class="legend">
          <span class="legend-item"><span class="swatch swatch-surface"></span> bg-surface</span>
          <span class="legend-item"><span class="swatch swatch-mid"></span> bg-surface-mid</span>
          <span class="legend-item"><span class="swatch swatch-card"></span> bg-card-dark</span>
          <span class="legend-item"><span class="swatch swatch-green"></span> accent green</span>
          <span class="legend-item"><span class="swatch swatch-mauve"></span> accent mauve</span>
          <span class="legend-item"><span class="swatch swatch-blue"></span> accent blue</span>
          <span class="legend-item"><span class="swatch swatch-crust"></span> bg-crust (page bg)</span>
        </div>
      </div>
    </header>

    <!-- ─── CANVAS ─── -->
    <div class="wireframe-canvas">
      <div class="max-w-6xl mx-auto px-6">

        <!-- ═══ NAVBAR ═══ -->
        <section class="wf-section" data-section="navbar">
          <div class="wf-label-group">
            <span class="wf-label">Navbar.vue</span>
            <span class="wf-file">src/components/Navbar.vue</span>
          </div>
          <div class="wf-navbar">
            <div class="wf-logo">Davy Andrade</div>
            <div class="wf-nav-links">
              <span class="wf-nav-item active">Hero</span>
              <span class="wf-nav-item">About</span>
              <span class="wf-nav-item">Projects</span>
              <span class="wf-nav-item">Experience</span>
            </div>
            <div class="wf-nav-cta">
              <span class="wf-pill">Contato →</span>
            </div>
          </div>
          <div class="wf-sidenote">Altura fixa · bg-crust · backdrop-blur · sticky top-0 · z-50</div>
        </section>

        <!-- ═══ HERO ═══ -->
        <section class="wf-section" data-section="hero">
          <div class="wf-label-group">
            <span class="wf-label">Hero.vue</span>
            <span class="wf-file">src/components/Hero.vue</span>
            <span class="wf-data">src/data/hero.json</span>
          </div>
          <div class="wf-hero">
            <div class="wf-hero-badge">
              <span class="wf-dot"></span> Disponível para projetos
            </div>
            <div class="wf-hero-title">
              <span class="wf-title-line">Davy Andrade</span>
              <span class="wf-title-line accent">Engenheiro de Software &amp; Design</span>
            </div>
            <div class="wf-hero-desc">
              Linha de descrição curta — foco em produto, experiência densa e acessível.
            </div>
            <div class="wf-hero-actions">
              <span class="wf-pill primary">Ver Projetos ↓</span>
              <span class="wf-pill outlined">Contato →</span>
              <span class="wf-icon-circle play"></span>
            </div>
          </div>
          <div class="wf-sidenote">
            Entrada com fade-in + slide-up · bg-crust (#11111b) · grain overlay
            <br />Typography: h1 (24px/700 SpotifyMixUITitle) + body (16px/400 SpotifyMixUI)
          </div>
        </section>

        <!-- ═══ ABOUT ═══ -->
        <section class="wf-section" data-section="about">
          <div class="wf-label-group">
            <span class="wf-label">About.vue</span>
            <span class="wf-file">src/components/About.vue</span>
            <span class="wf-data">src/data/about.json</span>
          </div>
          <div class="wf-about">
            <div class="wf-section-badge">Sobre</div>
            <div class="wf-about-grid">
              <div class="wf-avatar-box">
                <div class="wf-avatar"></div>
              </div>
              <div class="wf-about-text">
                <div class="wf-about-heading">Quem sou</div>
                <div class="wf-about-body">
                  <div class="wf-text-line w60"></div>
                  <div class="wf-text-line w80"></div>
                  <div class="wf-text-line w45"></div>
                  <div class="wf-text-line w70"></div>
                </div>
                <div class="wf-tags">
                  <span class="wf-tag">Vue</span>
                  <span class="wf-tag">Astro</span>
                  <span class="wf-tag">Tailwind</span>
                  <span class="wf-tag">TypeScript</span>
                  <span class="wf-tag">Bun</span>
                </div>
              </div>
            </div>
          </div>
          <div class="wf-sidenote">
            Card: bg-surface (#181825) · 8px radius · shadow-medium · avatar circular (--radius-circle)
          </div>
        </section>

        <!-- ═══ PROJECTS ═══ -->
        <section class="wf-section" data-section="projects">
          <div class="wf-label-group">
            <span class="wf-label">Projects.vue</span>
            <span class="wf-file">src/components/Projects.vue</span>
            <span class="wf-data">src/data/projects.json</span>
          </div>
          <div class="wf-projects">
            <div class="wf-section-badge">Projetos</div>
            <div class="wf-projects-grid">
              <div class="wf-project-card">
                <div class="wf-project-img"></div>
                <div class="wf-project-info">
                  <div class="wf-project-title">Nome do Projeto</div>
                  <div class="wf-project-desc">Descrição breve do projeto em uma linha.</div>
                  <div class="wf-project-tags">
                    <span class="wf-tag sm">Vue</span>
                    <span class="wf-tag sm">Tailwind</span>
                  </div>
                </div>
              </div>
              <div class="wf-project-card">
                <div class="wf-project-img"></div>
                <div class="wf-project-info">
                  <div class="wf-project-title">Outro Projeto</div>
                  <div class="wf-project-desc">Descrição breve do projeto em uma linha.</div>
                  <div class="wf-project-tags">
                    <span class="wf-tag sm">Astro</span>
                    <span class="wf-tag sm">Bun</span>
                  </div>
                </div>
              </div>
              <div class="wf-project-card">
                <div class="wf-project-img"></div>
                <div class="wf-project-info">
                  <div class="wf-project-title">Terceiro Projeto</div>
                  <div class="wf-project-desc">Descrição breve do projeto em uma linha.</div>
                  <div class="wf-project-tags">
                    <span class="wf-tag sm">TypeScript</span>
                    <span class="wf-tag sm">React</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="wf-sidenote">
            Grid 3 col → 2 col (tablet) → 1 col (mobile) · Card: bg-card-dark (#313244) · hover:shadow-heavy
          </div>
        </section>

        <!-- ═══ EXPERIENCE ═══ -->
        <section class="wf-section" data-section="experience">
          <div class="wf-label-group">
            <span class="wf-label">Experience.vue</span>
            <span class="wf-file">src/components/Experience.vue</span>
            <span class="wf-data">src/data/experience.json</span>
          </div>
          <div class="wf-experience">
            <div class="wf-section-badge">Experiência</div>
            <div class="wf-timeline">
              <div class="wf-timeline-item">
                <div class="wf-timeline-dot"></div>
                <div class="wf-timeline-card">
                  <div class="wf-timeline-title">Empresa Alpha</div>
                  <div class="wf-timeline-role">Engenheiro de Software</div>
                  <div class="wf-timeline-date">2024 — 2025</div>
                  <div class="wf-timeline-desc">Descrição das responsabilidades e entregas.</div>
                </div>
              </div>
              <div class="wf-timeline-item">
                <div class="wf-timeline-dot"></div>
                <div class="wf-timeline-card">
                  <div class="wf-timeline-title">Empresa Beta</div>
                  <div class="wf-timeline-role">Frontend Developer</div>
                  <div class="wf-timeline-date">2023 — 2024</div>
                  <div class="wf-timeline-desc">Descrição das responsabilidades e entregas.</div>
                </div>
              </div>
              <div class="wf-timeline-item">
                <div class="wf-timeline-dot"></div>
                <div class="wf-timeline-card">
                  <div class="wf-timeline-title">Empresa Gamma</div>
                  <div class="wf-timeline-role">Junior Developer</div>
                  <div class="wf-timeline-date">2022 — 2023</div>
                  <div class="wf-timeline-desc">Descrição das responsabilidades e entregas.</div>
                </div>
              </div>
            </div>
          </div>
          <div class="wf-sidenote">
            Timeline vertical · dot verde (--color-green) · cards bg-surface · linha separadora surface1
          </div>
        </section>

        <!-- ═══ CONTACT ═══ -->
        <section class="wf-section" data-section="contact">
          <div class="wf-label-group">
            <span class="wf-label">Contact.vue</span>
            <span class="wf-file">src/components/Contact.vue</span>
            <span class="wf-data">src/data/contact.json</span>
          </div>
          <div class="wf-contact">
            <div class="wf-section-badge">Contato</div>
            <div class="wf-contact-layout">
              <div class="wf-contact-text">
                <div class="wf-contact-heading">Vamos trabalhar juntos?</div>
                <div class="wf-contact-desc">
                  Estou disponível para novos projetos, freelas e oportunidades.
                  Me chame no email ou redes sociais.
                </div>
              </div>
              <div class="wf-contact-actions">
                <div class="wf-contact-email-box">
                  <span class="wf-contact-email-label">Email</span>
                  <a class="wf-contact-email-value" href="#">davyandrade.dev@gmail.com</a>
                </div>
                <div class="wf-contact-social">
                  <span class="wf-social-circle">GH</span>
                  <span class="wf-social-circle">LI</span>
                  <span class="wf-social-circle">@</span>
                </div>
              </div>
            </div>
          </div>
          <div class="wf-sidenote">
            Layout flex horizontal · Email em destaque com label + value verde · Social links em círculos
            <br />Sem formulário — apenas CTA direto para email e redes
          </div>
        </section>

        <!-- ═══ FOOTER ═══ -->
        <section class="wf-section" data-section="footer">
          <div class="wf-label-group">
            <span class="wf-label">Footer.vue</span>
            <span class="wf-file">src/components/Footer.vue</span>
            <span class="wf-data">src/data/footer.json</span>
          </div>
          <div class="wf-footer">
            <div class="wf-footer-links">
              <span class="wf-footer-link">GitHub</span>
              <span class="wf-footer-link">LinkedIn</span>
              <span class="wf-footer-link">Email</span>
            </div>
            <div class="wf-footer-copy">© 2026 Davy Andrade</div>
          </div>
          <div class="wf-sidenote">bg-crust · border-top surface1 · links com hover green</div>
        </section>

        <!-- ═══ DATA FLOW DIAGRAM ═══ -->
        <section class="wf-section" data-section="dataflow">
          <div class="wf-label-group">
            <span class="wf-label">Fluxo de Dados</span>
          </div>
          <div class="wf-dataflow">
            <div class="df-row">
              <div class="df-box data">src/data/<br />hero.json</div>
              <div class="df-arrow">→</div>
              <div class="df-box comp">Hero.vue</div>
              <div class="df-arrow">→</div>
              <div class="df-box page">index.astro</div>
            </div>
            <div class="df-row">
              <div class="df-box data">src/data/<br />about.json</div>
              <div class="df-arrow">→</div>
              <div class="df-box comp">About.vue</div>
              <div class="df-arrow">→</div>
              <div class="df-box page">index.astro</div>
            </div>
            <div class="df-row">
              <div class="df-box data">src/data/<br />projects.json</div>
              <div class="df-arrow">→</div>
              <div class="df-box comp">Projects.vue</div>
              <div class="df-arrow">→</div>
              <div class="df-box page">index.astro</div>
            </div>
            <div class="df-row">
              <div class="df-box data">src/data/<br />experience.json</div>
              <div class="df-arrow">→</div>
              <div class="df-box comp">Experience.vue</div>
              <div class="df-arrow">→</div>
              <div class="df-box page">index.astro</div>
            </div>
            <div class="df-row">
              <div class="df-box data">src/data/<br />footer.json</div>
              <div class="df-arrow">→</div>
              <div class="df-box comp">Footer.vue</div>
              <div class="df-arrow">→</div>
              <div class="df-box page">index.astro</div>
            </div>
            <div class="df-row df-glue">
              <div class="df-box page full">Layout.astro (shell — importa global.css)</div>
            </div>
          </div>
          <div class="wf-sidenote">
            Cada seção lê seu .json correspondente · Layout.astro fornece HTML base + fontes + tokens
          </div>
        </section>

        <!-- ═══ DESIGN TOKENS TABLE ═══ -->
        <section class="wf-section" data-section="tokens">
          <div class="wf-label-group">
            <span class="wf-label">Design Tokens</span>
            <span class="wf-file">src/styles/theme.css + tailwind.css</span>
          </div>
          <div class="wf-tokens">
            <table class="token-table">
              <thead>
                <tr><th>Tailwind Class</th><th>CSS Variable</th><th>Catppuccin</th><th>Hex</th><th>Swatch</th></tr>
              </thead>
              <tbody>
                <tr><td><code>bg-surface</code></td><td>--color-surface</td><td>Mantle</td><td>#181825</td><td><span class="swatch sm" style="background:#181825"></span></td></tr>
                <tr><td><code>bg-surface-mid</code></td><td>--color-surface-mid</td><td>Base</td><td>#1e1e2e</td><td><span class="swatch sm" style="background:#1e1e2e"></span></td></tr>
                <tr><td><code>bg-card-dark</code></td><td>--color-card-dark</td><td>Surface0</td><td>#313244</td><td><span class="swatch sm" style="background:#313244"></span></td></tr>
                <tr><td><code>text-muted</code></td><td>--color-muted</td><td>Subtext0</td><td>#a6adc8</td><td><span class="swatch sm" style="background:#a6adc8"></span></td></tr>
                <tr><td><code>text-near-white</code></td><td>--color-near-white</td><td>Subtext1</td><td>#bac2de</td><td><span class="swatch sm" style="background:#bac2de"></span></td></tr>
                <tr><td><code>text-green</code></td><td>--color-green</td><td>Green</td><td>#a6e3a1</td><td><span class="swatch sm" style="background:#a6e3a1"></span></td></tr>
                <tr><td><code>text-mauve</code></td><td>--color-mauve</td><td>Mauve</td><td>#cba6f7</td><td><span class="swatch sm" style="background:#cba6f7"></span></td></tr>
                <tr><td><code>text-blue</code></td><td>--color-blue</td><td>Blue</td><td>#89b4fa</td><td><span class="swatch sm" style="background:#89b4fa"></span></td></tr>
              </tbody>
            </table>
          </div>
        </section>

      </div>
    </div>
  </div>
</Layout>

<style is:global>
  /* ─── Wireframe Specific Styles ─── */
  .wireframe {
    font-family: "Inter Variable", system-ui, sans-serif;
  }

  .wireframe-header {
    border-bottom: 1px dashed var(--catppuccin-color-surface1);
    background: var(--catppuccin-color-crust);
  }

  .wireframe-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--catppuccin-color-text);
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .wireframe-subtitle {
    font-size: 0.875rem;
    color: var(--catppuccin-color-subtext0);
    margin-bottom: 1.25rem;
  }

  /* ─── Legend ─── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--catppuccin-color-surface0);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--catppuccin-color-overlay2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 3px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .swatch.sm {
    width: 18px;
    height: 18px;
  }

  .swatch-surface { background: var(--catppuccin-color-mantle); }
  .swatch-mid     { background: var(--catppuccin-color-base); }
  .swatch-card    { background: var(--catppuccin-color-surface0); }
  .swatch-green   { background: var(--catppuccin-color-green); }
  .swatch-mauve   { background: var(--catppuccin-color-mauve); }
  .swatch-blue    { background: var(--catppuccin-color-blue); }
  .swatch-crust   { background: var(--catppuccin-color-crust); }

  /* ─── Canvas ─── */
  .wireframe-canvas {
    padding: 2rem 0 4rem;
  }

  /* ─── Section Block ─── */
  .wf-section {
    margin-bottom: 2.5rem;
    position: relative;
  }

  .wf-section[data-section]::before {
    content: "";
    position: absolute;
    inset: -0.75rem -0.75rem -0.75rem -0.75rem;
    border: 1px dashed var(--catppuccin-color-surface1);
    border-radius: 10px;
    opacity: 0.4;
    pointer-events: none;
  }

  .wf-section[data-section] {
    padding: 0.75rem;
  }

  .wf-label-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding-left: 0.25rem;
  }

  .wf-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--catppuccin-color-mauve);
    background: color-mix(in srgb, var(--catppuccin-color-mauve) 12%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .wf-file,
  .wf-data {
    font-size: 0.65rem;
    font-family: "JetBrains Mono", "Fira Code", monospace;
    color: var(--catppuccin-color-overlay1);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: var(--catppuccin-color-surface0);
  }

  .wf-data {
    color: var(--catppuccin-color-blue);
    background: color-mix(in srgb, var(--catppuccin-color-blue) 10%, transparent);
  }

  .wf-sidenote {
    font-size: 0.65rem;
    color: var(--catppuccin-color-overlay0);
    padding-left: 0.25rem;
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  /* ─── Section Badge ─── */
  .wf-section-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--catppuccin-color-green);
    background: color-mix(in srgb, var(--catppuccin-color-green) 10%, transparent);
    padding: 0.15rem 0.6rem;
    border-radius: 500px;
    margin-bottom: 1rem;
  }

  /* ─── Navbar ─── */
  .wf-navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.25rem;
    background: var(--catppuccin-color-crust);
    border: 1px solid var(--catppuccin-color-surface1);
    border-radius: 8px;
  }

  .wf-logo {
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--catppuccin-color-text);
  }

  .wf-nav-links {
    display: flex;
    gap: 1.25rem;
  }

  .wf-nav-item {
    font-size: 0.8125rem;
    color: var(--catppuccin-color-subtext0);
    cursor: default;
  }

  .wf-nav-item.active {
    color: var(--catppuccin-color-text);
    font-weight: 600;
  }

  .wf-nav-cta .wf-pill {
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
  }

  /* ─── Hero ─── */
  .wf-hero {
    padding: 2.5rem 1.5rem;
    background: var(--catppuccin-color-crust);
    border: 1px solid var(--catppuccin-color-surface0);
    border-radius: 10px;
    text-align: center;
  }

  .wf-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--catppuccin-color-green);
    background: color-mix(in srgb, var(--catppuccin-color-green) 10%, transparent);
    padding: 0.25rem 0.75rem;
    border-radius: 500px;
    margin-bottom: 1.25rem;
  }

  .wf-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--catppuccin-color-green);
    display: inline-block;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .wf-hero-title {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .wf-title-line {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--catppuccin-color-text);
    letter-spacing: -0.02em;
  }

  .wf-title-line.accent {
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--catppuccin-color-subtext0);
  }

  .wf-hero-desc {
    font-size: 0.875rem;
    color: var(--catppuccin-color-overlay1);
    max-width: 28rem;
    margin: 0 auto 1.25rem;
  }

  .wf-hero-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }

  /* ─── Pills ─── */
  .wf-pill {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 1.25rem;
    border-radius: 500px;
    background: var(--catppuccin-color-base);
    color: var(--catppuccin-color-text);
    border: 1px solid var(--catppuccin-color-surface1);
    cursor: default;
  }

  .wf-pill.primary {
    background: var(--catppuccin-color-green);
    color: var(--catppuccin-color-crust);
    border-color: var(--catppuccin-color-green);
  }

  .wf-pill.outlined {
    background: transparent;
    border-color: var(--catppuccin-color-overlay0);
    color: var(--catppuccin-color-text);
  }

  .wf-icon-circle {
    display: inline-block;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--catppuccin-color-green);
    cursor: default;
  }

  .wf-icon-circle.play::after {
